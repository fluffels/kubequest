{
  // Ratchet-Konfig: hält bereits gehärtete Module auf strenger Typprüfung.
  // Prüfen mit:  npm run typecheck:strict
  //
  // Stufe 1 (jetzt): strictNullChecks & Co. für die puren Domänen-Module, die
  //   sauber bestehen. Lockt deren Null-/Property-Sicherheit ein – künftige
  //   Edits, die das verletzen, fallen sofort auf.
  // Geplant: sim.ts härten (eigener Durchgang) -> dann noImplicitAny anschalten
  //   (Param-Typen) -> am Ende kann die Basis-tsconfig selbst auf strict.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false
  },
  "include": ["src/types.ts", "src/store.ts", "src/content.ts"]
}
