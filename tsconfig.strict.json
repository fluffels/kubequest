{
  // Strict-Ratchet ABGESCHLOSSEN: die Basis-tsconfig.json steht selbst auf
  // "strict": true und deckt das ganze Projekt ab (src inkl. scenes/ui/main,
  // test, vite.config). Diese Datei ist nur noch ein Alias, damit das
  // gewohnte `npm run typecheck:strict` weiter funktioniert – sie prüft
  // jetzt exakt dasselbe wie `npm run typecheck`.
  //
  // Historie der Stufen:
  //   Stufe 1: strictNullChecks & Co. für die puren Domänen-Module.
  //   Stufe 2: noImplicitAny für types/store/content/sim/game.
  //   Stufe 3: scenes/ui/main/sfx + Tests nachgezogen, Basis global auf strict.
  "extends": "./tsconfig.json"
}
